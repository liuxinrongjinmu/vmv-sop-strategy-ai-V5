{
  "version": 2,
  "build": {
    "env": {
      "VITE_API_URL": "https://incredible-harmony-production-2226.up.railway.app"
    }
  },
  "buildCommand": "npm install && npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "rootDirectory": "frontend",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}